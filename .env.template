# === ChirpStack/TTN Configuration ===
VITE_CHIRPSTACK_API_URL=https://your-chirpstack-url.com:8090
VITE_CHIRPSTACK_DEVICE_ID=your-device-id-here
VITE_CHIRPSTACK_AUTH_TOKEN=your-auth-token-here

# === Relay Authentication Token ===
# Generate a strong token: openssl rand -hex 32
RELAY_AUTH_TOKEN=your-relay-token-here

# === CORS Configuration ===
# Comma-separated list of allowed origins (optional)
# ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com

# === Server Configuration ===
# PORT is automatically set by Render/Railway, but can be overridden locally
# PORT=3000

# === Environment ===
NODE_ENV=production
